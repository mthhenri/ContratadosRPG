# Template de configuração de ambiente (SYSTEM.SPEC §10.6).
# Copie para `.env` (git-ignored) e ajuste os valores para o seu ambiente.
# O Docker Compose lê este `.env` para subir o Postgres; o Knex (knexfile.ts) lê a
# conexão do banco a partir dele. O código da aplicação (a partir da task m0-03) lê tudo
# via ConfigService injetado — nunca process.env direto.

# Banco de dados
DB_HOST=localhost
DB_PORT=5432
DB_NOME=contratados_rpg
DB_USUARIO=postgres
DB_SENHA=postgres

# JWT
JWT_SECRETO=troque-em-producao
JWT_EXPIRACAO=8h

# Aplicação
APP_PORTA=3100
APP_AMBIENTE=development
APP_FRONTEND_ORIGEM=http://localhost:4300
